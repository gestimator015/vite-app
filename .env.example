# JaaS (Jitsi as a Service) — https://jaas.8x8.vc
# Get these from your JaaS dashboard under API keys
VITE_JAAS_APP_ID=vpaas-magic-cookie-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_JAAS_KEY_ID=vpaas-magic-cookie-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx/xxxxxx
# Paste the full RSA private key PEM (newlines stored as \n in Vercel env vars)
JAAS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
